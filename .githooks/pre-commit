#!/usr/bin/env bash
# Pre-commit: block secrets from being committed (staged changes only).
# Enable with:  make hooks   (or)   just hooks   (sets core.hooksPath=.githooks)
set -euo pipefail

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "pre-commit: gitleaks not installed — skipping secret scan (brew install gitleaks)" >&2
  exit 0
fi

git_err="$(mktemp)"
trap 'rm -f "$git_err"' EXIT

if gitleaks git --staged --no-banner --redact 2>"$git_err"; then
  exit 0
elif grep -Eiq 'unknown command|unknown flag|No help topic' "$git_err" \
  && gitleaks protect --staged --no-banner --redact; then
  exit 0
else
  cat "$git_err" >&2
  echo "pre-commit: gitleaks found potential secrets — commit blocked." >&2
  echo "            review the findings above; to override (rarely): git commit --no-verify" >&2
  exit 1
fi
